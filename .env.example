INPUT_GITHUB-TOKEN=ghp_your_personal_access_token
INPUT_MANIFEST-FILE=package.json
INPUT_INCLUDE-DEV=false
INPUT_FAIL-THRESHOLD=30
INPUT_WARN-THRESHOLD=60
INPUT_DOWNLOAD-FLOOR=500000
